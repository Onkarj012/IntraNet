# =============================================================================
# IntradayNet + OptiNet — .gitignore
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
*.whl
dist/
build/
eggs/

# Virtual environments
.venv/
venv/
ENV/
.uv_cache/

# ── Data (large, downloadable/regeneratable) ─────────────────────────────────
# Nifty 500 minute bars (~20 GB)
data/nifty500/
data/nifty_intraday/
data/banknifty_intraday/
data/indices_minute/

# F&O raw downloads and parquet lake (~1 GB)
data/raw/
data/parquet/
data/normalized/
data/metadata/

# Sentiment CSVs (regeneratable)
data/sentiment/

# yfinance daily CSVs
data/yfinance_daily/

# US stock data
data/us/

# Option chain data
data/option_data/

# OptiNet intermediate data
data/optinet/

# ── Data we DO track ─────────────────────────────────────────────────────────
# data/prices/ — 42 EOD reference CSVs (13 MB)
# data/indices/ — nifty_daily.csv, banknifty_daily.csv
# data/README.md

# ── Models (large binaries) ──────────────────────────────────────────────────
models/

# ── Cache & Generated Output ─────────────────────────────────────────────────
cache/
market_data_cache/
graphify-out/
outputs/
nifty500/

# ── Results & Recommendations (generated) ────────────────────────────────────
results/
recommendations/
backtest_results/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Ledger (append-only paper trading data) ──────────────────────────────────
ledger/

# ── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE & Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
.codex/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
._*
Thumbs.db
Desktop.ini

# ── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
credentials.json
secrets.yaml

# ── Misc ─────────────────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup
flags/
