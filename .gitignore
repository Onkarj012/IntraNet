# =============================================================================
# IntradayNet + OptiNet — .gitignore
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/
.venv/
.uv_cache/

# ── Large data (downloadable/regeneratable) ───────────────────────────────────
data/nifty500/
data/nifty_intraday/
data/banknifty_intraday/
data/indices_minute/
data/option_data/
data/raw/
data/parquet/
data/normalized/
data/sentiment/
data/yfinance_daily/
data/us/
data/optinet/
data/metadata/

# ── Small data we DO track ────────────────────────────────────────────────────
# data/prices/    — 42 EOD reference CSVs
# data/indices/   — nifty_daily.csv, banknifty_daily.csv
# data/README.md

# ── Models ────────────────────────────────────────────────────────────────────
models/
*.pkl
*.pt
*.pth
*.lgb
*.onnx
*.bin

# ── Cache & generated output ──────────────────────────────────────────────────
cache/
market_data_cache/
graphify-out/
outputs/
nifty500/

# ── Results & recommendations ─────────────────────────────────────────────────
results/
recommendations/
backtest_results/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Ledger ────────────────────────────────────────────────────────────────────
ledger/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
.codex/
.DS_Store
._*
*.swp
*~

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tmp
*.bak
flags/
